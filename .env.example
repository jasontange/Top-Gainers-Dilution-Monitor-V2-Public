# Ask Edgar API Key (request a free trial at https://www.askedgar.io/api-trial)
# One key works for all endpoints (dilution rating, float, news, screener, dilution data, gap stats, offerings)
ASKEDGAR_API_KEY=your_askedgar_api_key_here

# TradingView session cookie (optional — enables real-time prices instead of 15-min delayed)
# Get from Chrome DevTools: F12 > Application > Cookies > tradingview.com > sessionid
TRADINGVIEW_SESSION_ID=your_session_id_here
